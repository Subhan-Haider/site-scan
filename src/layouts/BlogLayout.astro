---
import Base from '@layouts/Base.astro';
import Footer from '../client/components/misc/Footer';
import Nav from '../client/components/Form/Nav';

const { frontmatter } = Astro.props;
---

<Base title={frontmatter.title} description={frontmatter.description}>
  <div class="blog-layout-wrapper">
    <!-- Wrap the nav to reuse the styled React component -->
    <Nav client:load />
    
    <main class="blog-container">
      <a href="/blog" class="back-link">← Back to Blog</a>
      <article>
        <header class="blog-header">
          <h1>{frontmatter.title}</h1>
          <p class="blog-meta">
            By <strong>{frontmatter.author}</strong> on {new Date(frontmatter.pubDate).toLocaleDateString()}
          </p>
        </header>
        
        <div class="markdown-content">
          <slot />
        </div>
      </article>
    </main>

    <Footer client:load />
  </div>
</Base>

<style>
  .blog-layout-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background: #ffffff; /* Explicit light theme */
    color: #1a1a1a;
  }

  .blog-container {
    flex: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    width: 100%;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: #4a7700;
    text-decoration: none;
    font-weight: 500;
  }
  .back-link:hover {
    text-decoration: underline;
  }

  .blog-header {
    margin-bottom: 3rem;
    border-bottom: 2px solid #f0f0f0;
    padding-bottom: 1.5rem;
  }

  .blog-header h1 {
    font-size: 2.5rem;
    color: #4a7700;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .blog-meta {
    color: #666;
    font-size: 0.95rem;
  }

  .markdown-content {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #333;
  }

  /* Basic Markdown Styling */
  .markdown-content :global(h2) {
    font-size: 1.8rem;
    color: #4a7700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .markdown-content :global(h3) {
    font-size: 1.4rem;
    color: #4a7700;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .markdown-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .markdown-content :global(ul), .markdown-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  .markdown-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .markdown-content :global(a) {
    color: #0066cc;
    text-decoration: none;
  }

  .markdown-content :global(a:hover) {
    text-decoration: underline;
  }

  .markdown-content :global(blockquote) {
    border-left: 4px solid #4a7700;
    background: #f9f9f9;
    padding: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: #555;
  }

  .markdown-content :global(pre) {
    background: #1a1a1a;
    color: #fff;
    padding: 1.2rem;
    border-radius: 6px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  
  .markdown-content :global(code) {
    font-family: 'Courier New', Courier, monospace;
    background: #f0f0f0;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.95em;
    color: #cc3300;
  }
  
  .markdown-content :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }
  
  .markdown-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    margin: 2rem 0;
  }
</style>
