---
import Base from '@layouts/Base.astro';
import Footer from '../client/components/misc/Footer';
import Nav from '../client/components/Form/Nav';

const { frontmatter } = Astro.props;
---

<Base title={frontmatter.title} description={frontmatter.description}>
  <div class="blog-layout-wrapper">
    <!-- Wrap the nav to reuse the styled React component -->
    <Nav client:load />
    
    <main class="blog-container">
      <a href="/blog" class="back-link">← Back to Blog</a>
      <article>
        <header class="blog-header">
          <h1>{frontmatter.title}</h1>
          <p class="blog-meta">
            By <strong>{frontmatter.author}</strong> on {new Date(frontmatter.pubDate).toLocaleDateString()}
          </p>
        </header>
        
        <div class="markdown-content">
          <slot />
        </div>
      </article>
    </main>

    <Footer client:load />
  </div>
</Base>

<style>
  .blog-layout-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    background: var(--background);
    color: var(--text-color);
  }

  .blog-container {
    flex: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    width: 100%;
  }

  .blog-header {
    margin-bottom: 3rem;
    text-align: center;
  }

  .blog-title {
    font-size: 2.5rem;
    color: var(--primary);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .blog-meta {
    font-size: 1rem;
    color: var(--text-color-secondary);
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .blog-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-color);
  }

  .blog-content :global(h2) {
    font-size: 1.8rem;
    color: var(--text-color);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .blog-content :global(h3) {
    font-size: 1.4rem;
    color: var(--text-color);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .blog-content :global(p) {
    margin-bottom: 1.5rem;
  }

  .blog-content :global(a) {
    color: var(--primary);
    text-decoration: none;
  }

  .blog-content :global(a:hover) {
    text-decoration: underline;
  }

  .blog-content :global(ul), 
  .blog-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .blog-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .blog-content :global(blockquote) {
    border-left: 4px solid var(--primary);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-color-secondary);
    font-style: italic;
  }

  .blog-content :global(code) {
    background: var(--background-darker);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  .blog-content :global(pre) {
    background: var(--background-darker);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .blog-content :global(pre code) {
    background: none;
    padding: 0;
  }
  .blog-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 6px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    margin: 2rem 0;
  }
</style>
